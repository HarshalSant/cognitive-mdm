# CognitiveMDM Environment Configuration
# Copy to .env and fill in your values

# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cognitive_mdm
POSTGRES_USER=mdm
POSTGRES_PASSWORD=mdmpassword
DATABASE_URL=postgresql+asyncpg://mdm:mdmpassword@postgres:5432/cognitive_mdm

# ─── Neo4j ──────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword

# ─── Qdrant ─────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Kafka ──────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_CONSUMER_GROUP=cognitive-mdm

# ─── AI Providers ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OLLAMA_BASE_URL=http://ollama:11434

# ─── Embedding Models ───────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
EMBEDDING_DIM=768
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# ─── Security ───────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-256-bit-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ENCRYPTION_KEY=your-32-byte-encryption-key

# ─── Observability ──────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=cognitive-mdm
LOG_LEVEL=INFO
GRAFANA_PASSWORD=admin

# ─── Application ────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
API_RATE_LIMIT=1000
